{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^db:generate"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "dependsOn": ["^db:generate", "^build"],
      "persistent": true,
      "cache": false
    },
    "check": {
      "dependsOn": ["^build", "^db:generate"]
    },
    "lint": {
      "dependsOn": ["^build", "^db:generate"]
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
