# ── Required (web + worker) ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/ammo_exchange
CHAIN=fuji                                        # "fuji" or "mainnet" — drives chain, contracts, and explorer URLs
RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# ── Required (web only) ─────────────────────────────────────────────
SESSION_SECRET=generate-with-openssl-rand-hex-32
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id
APP_DOMAIN=localhost:3000                         # SIWE verification domain (no protocol)
APP_URL=http://localhost:3000                     # SIWE verification URI (with protocol)

# ── Optional (web only) ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
FAUCET_PRIVATE_KEY=0x...                          # 0x-prefixed, 66 chars — faucet disabled when absent
SHIPPO_API_KEY=shippo_test_...                     # Shippo address validation — skipped when absent

# ── Optional (worker only) ──────────────────────────────────────────
POLL_INTERVAL_MS=4000                             # Event polling interval (default: 4000ms)
