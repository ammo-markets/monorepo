generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ───────────────────────────────────────

enum KycStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum OrderType {
  MINT
  REDEEM
}

enum OrderStatus {
  PENDING
  APPROVED
  PAID
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum Caliber {
  NINE_MM_PRACTICE
  NINE_MM_SELF_DEFENSE
  FIVE_FIVE_SIX_SELF_DEFENSE
  FIVE_FIVE_SIX_NATO_PRACTICE
}

// ── Models ──────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  walletAddress String    @unique
  kycStatus     KycStatus @default(NONE)

  // KYC identity data (collected during verification)
  kycFullName    String?
  kycDateOfBirth DateTime?
  kycState       String?    // 2-letter state code
  kycGovIdType   String?    // DRIVERS_LICENSE, PASSPORT, STATE_ID
  kycGovIdNumber String?
  kycRejectionReason String?
  kycSubmittedAt     DateTime?
  kycReviewedAt      DateTime?

  // Default shipping address (reusable across orders)
  defaultShippingName  String?
  defaultShippingLine1 String?
  defaultShippingLine2 String?
  defaultShippingCity  String?
  defaultShippingState String?  // 2-letter state code
  defaultShippingZip   String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders      Order[]
  preferences UserPreference?

  @@index([walletAddress])
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  type            OrderType
  status          OrderStatus @default(PENDING)
  caliber         Caliber
  usdcAmount      String?
  tokenAmount     String?
  onChainOrderId  String?
  walletAddress   String?
  txHash          String?
  mintPrice       String?     // Oracle price used for 1-step mint (18-decimal string). Null for REDEEM orders.
  refundAmount    String?     // Dust refund from rounding (18-decimal string)
  feeAmount       String?     // Fee charged (18-decimal string)
  shippingCost    String?     // shipping cost set by admin on approval (decimal string)
  protocolFee     String?     // protocol fee auto-calculated on approval (decimal string)
  trackingId      String?     // UPS tracking ID added by admin after shipping
  paidAt          DateTime?   // When user paid shipping + protocol fee
  backedAt        DateTime?   // null = unbacked, set = physically backed
  backedBy        String?     // keeper wallet who marked it backed
  logIndex        Int
  chainId         Int
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user            User             @relation(fields: [userId], references: [id])
  shippingAddress ShippingAddress?

  @@unique([txHash, logIndex])
  @@index([userId])
  @@index([txHash])
  @@index([status])
  @@index([walletAddress])
  @@index([onChainOrderId])
  @@index([type, status, backedAt])
}

model ShippingAddress {
  id      String  @id @default(cuid())
  orderId String  @unique
  name    String
  line1   String
  line2   String?
  city    String
  state   String
  zip     String

  order Order @relation(fields: [orderId], references: [id])
}

model Inventory {
  id        String   @id @default(cuid())
  caliber   Caliber  @unique
  rounds    BigInt   @default(0)
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}

model BlockCursor {
  id              String   @id @default(cuid())
  contractAddress String   @unique
  chainId         Int
  lastBlock       BigInt   @default(0)
  updatedAt       DateTime @updatedAt

  @@index([contractAddress])
}

model ProtocolStats {
  id            String   @id @default(cuid())
  caliber       Caliber  @unique
  totalMinted   String   @default("0")
  totalRedeemed String   @default("0")
  netSupply     String   @default("0")
  userCount     Int      @default(0)
  computedAt    DateTime @default(now())

  @@index([caliber])
}

model ActivityLog {
  id            String    @id @default(cuid())
  type          OrderType
  caliber       Caliber
  amount        String
  txHash        String
  logIndex      Int       @default(0)
  walletAddress String
  createdAt     DateTime  @default(now())

  @@unique([txHash, logIndex])
  @@index([walletAddress])
  @@index([createdAt])
  @@index([type])
}

model UserPreference {
  id               String    @id @default(cuid())
  userId           String    @unique
  favoriteCalibers Caliber[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model CaliberPrice {
  id        String   @id @default(cuid())
  caliber   Caliber  @unique
  price     String               // cents string e.g. "57" for $0.57
  priceX18  String               // 18-decimal for on-chain: "570000000000000000"
  source    String   @default("ammosquared")
  updatedAt DateTime @updatedAt

  @@index([caliber])
}

model PriceSnapshot {
  id        String   @id @default(cuid())
  caliber   Caliber
  price     String               // cents string
  source    String   @default("ammosquared")
  createdAt DateTime @default(now())

  @@index([caliber, createdAt])
}

model MarketConfig {
  id            String   @id @default(cuid())
  caliber       Caliber  @unique
  mintFeeBps    Int      @default(150)
  redeemFeeBps  Int      @default(150)
  minMintRounds Int      @default(50)
  paused        Boolean  @default(false)
  updatedAt     DateTime @updatedAt

  @@index([caliber])
}
