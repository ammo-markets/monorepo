generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ───────────────────────────────────────

enum KycStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum OrderType {
  MINT
  REDEEM
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum Caliber {
  NINE_MM
  FIVE_FIVE_SIX
  TWENTY_TWO_LR
  THREE_OH_EIGHT
}

// ── Models ──────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  walletAddress String    @unique
  kycStatus     KycStatus @default(NONE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders Order[]

  @@index([walletAddress])
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  type            OrderType
  status          OrderStatus @default(PENDING)
  caliber         Caliber
  amount          String
  onChainOrderId  String?
  walletAddress   String?
  txHash          String?     @unique
  chainId         Int
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user            User             @relation(fields: [userId], references: [id])
  shippingAddress ShippingAddress?

  @@index([userId])
  @@index([txHash])
  @@index([status])
  @@index([walletAddress])
  @@index([onChainOrderId])
}

model ShippingAddress {
  id      String  @id @default(cuid())
  orderId String  @unique
  name    String
  line1   String
  line2   String?
  city    String
  state   String
  zip     String

  order Order @relation(fields: [orderId], references: [id])
}

model Inventory {
  id        String   @id @default(cuid())
  caliber   Caliber  @unique
  rounds    BigInt   @default(0)
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}

model BlockCursor {
  id              String   @id @default(cuid())
  contractAddress String   @unique
  chainId         Int
  lastBlock       BigInt   @default(0)
  updatedAt       DateTime @updatedAt

  @@index([contractAddress])
}
