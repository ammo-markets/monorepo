{
  "name": "@ammo-exchange/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed-stats": "tsx src/seed-stats.ts",
    "db:seed-prices": "tsx src/seed-price-history.ts",
    "db:test-seed": "tsx src/test-seed.ts",
    "db:reset": "prisma migrate reset",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.11",
    "dotenv": "^16.4.7",
    "prisma": "^7.3.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
