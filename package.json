{
  "name": "ammo-exchange",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "check": "turbo check",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:studio": "pnpm --filter @ammo-exchange/db exec prisma studio",
    "db:reset": "pnpm --filter @ammo-exchange/db db:reset",
    "contracts:build": "pnpm --filter @ammo-exchange/contracts build",
    "contracts:test": "pnpm --filter @ammo-exchange/contracts test",
    "contracts:fuji:check": "make -C packages/contracts fuji_check",
    "contracts:fuji:deploy": "make -C packages/contracts fuji_deploy",
    "worker:reset": "pnpm --filter @ammo-exchange/worker reset"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3"
  }
}
