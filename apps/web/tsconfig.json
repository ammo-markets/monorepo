{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    },
    "incremental": true,
    "noEmit": true,
    "allowJs": true
  },
  "include": ["*.ts", "*.tsx", "next-env.d.ts", "app", "features", "components", "hooks", "lib", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
