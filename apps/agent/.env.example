# Telegram
TELEGRAM_BOT_TOKEN=
# Comma-separated numeric Telegram user IDs allowed to use the bot. Get yours by messaging @userinfobot.
TELEGRAM_ALLOWED_USER_IDS=

# OpenRouter — one key, any model. https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Model slug. See https://openrouter.ai/models. Sonnet 4.6 is the recommended default
# for short-form creative copy (best voice per blind evals, ~$13/mo at low volume).
LLM_MODEL=anthropic/claude-sonnet-4.6
# Comma-separated fallback models if the primary fails. OpenRouter tries in order.
LLM_FALLBACK_MODELS=anthropic/claude-opus-4.7,openai/gpt-5

# Twitter (X) OAuth 1.0a User Context. Generate all four from developer.x.com > your app > Keys and tokens.
# The app must have "Read and Write" permission.
# If DRY_RUN=true, you can put any non-empty placeholder values here — the X API is never called.
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Storage directory for posted.json and memory.md. Use a persistent volume on Railway.
DATA_DIR=./data

# Set to "true" to test the bot end-to-end without an X dev account.
# Approvals will log the would-be tweet to console + chat, instead of calling the X API.
DRY_RUN=false
